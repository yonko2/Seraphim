# Telegram API credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+your_phone_number

# Operator Telegram user ID (who receives emergency calls)
OPERATOR_TELEGRAM_ID=operator_user_id

# AI Vision API key (set ONE of these — Groq is preferred)
# Get Groq key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# Google Gemini API key (fallback — used only if GROQ_API_KEY is not set)
# GEMINI_API_KEY=your_gemini_api_key

# Server config
HOST=0.0.0.0
PORT=8000
